# ─── Travel Platform Frontend ─── Development ───────────────────────────────
# Backend (NestJS) must be running at this URL
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# App info
NEXT_PUBLIC_APP_NAME=Tramps Aviation

# Set to "true" to use mock data (no backend needed)
NEXT_PUBLIC_USE_MOCK=false

NEXT_PUBLIC_ENV=development

# Dev path bar — set to your actual project folder path
NEXT_PUBLIC_PROJECT_ROOT=D:\Web App	ramps-aviation	ramps-aviation-frontend
