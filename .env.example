# Copy this to .env.local or .env.development

# Backend API URL (NestJS travel backend)
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# App name shown in UI
NEXT_PUBLIC_APP_NAME=TravelPro

# Use mock data? (true = no backend needed for testing)
NEXT_PUBLIC_USE_MOCK=false

NEXT_PUBLIC_ENV=development
